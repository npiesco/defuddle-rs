{
	"compilerOptions": {
		"target": "ES2021",
		"module": "ES2022",
		"moduleResolution": "bundler",
		"lib": ["ES2021", "DOM", "DOM.Iterable"],
		"types": ["@cloudflare/workers-types"],
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"outDir": "./dist",
		"rootDir": "."
	},
	"include": ["src/**/*", "../src/**/*"]
}
