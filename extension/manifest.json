{
  "manifest_version": 3,
  "name": "Defuddle RS Capture",
  "version": "0.1.0",
  "description": "Capture the current browser tab and open it in the Defuddle RS extension UI.",
  "permissions": [
    "activeTab",
    "sidePanel",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "panel.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "action": {
    "default_title": "Send page to Defuddle RS"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_start"
    }
  ]
}
